# ================================================================
# PAKASIR RAILWAY SERVER — ENV
# ================================================================

# Pakasir API Key (dari dashboard app.pakasir.com)
PAKASIR_API_KEY=isi_api_key_pakasir

# Nama project di Pakasir
PAKASIR_PROJECT=nama_project

# Slug halaman pembayaran (default: kirimkode)
# URL final: https://app.pakasir.com/pay/<PAKASIR_SLUG>/<order_id>?qris_only=1
PAKASIR_SLUG=kirimkode

# Secret untuk validasi webhook dari Pakasir (isi jika Pakasir support)
WEBHOOK_SECRET=

# Secret untuk endpoint internal (bot harus kirim X-Internal-Key: nilai_ini)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=ganti_dengan_32_char_acak

# Bot Token untuk tiap prefix order_id
# BOTA = order_id diawali "BOTA...", dst
BOT_TOKEN_A=1234567890:ABCdef...
BOT_TOKEN_B=

# Path database (Railway: bisa pakai volume, default ./data/pakasir.db)
DB_PATH=./data/pakasir.db

# Port (Railway isi otomatis)
PORT=3000
